allow-lan: false
bind-address: 127.0.0.1
mixed-port: 7890
mode: Rule
log-level: info

external-controller: 9090

unified-delay: true
tcp-concurrent: true

profile:
  store-selected: true
  store-fake-ip: true

dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  use-hosts: true

  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 180.76.76.76

  nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 180.76.76.76
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
    - https://doh.pub/dns-query

  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "localhost"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "time.*.com"
    - "time.*.gov"
    - "time.*.edu.cn"
    - "ntp.*.com"
    - "time1.cloud.tencent.com"

proxy-providers:
  ✈️ 我的机场:
    type: http
    url: "请替换为重置后的新订阅地址"
    interval: 3600
    path: ./wodejichang.yaml
    health-check:
      enable: true
      interval: 300
      timeout: 5000
      url: https://cp.cloudflare.com/generate_204

proxy-groups:
  - name: 🔰 节点选择
    type: select
    proxies:
      - ♻️ 自动选择
      - ⚖️ 负载均衡
      - 🎯 本地直连
    use:
      - ✈️ 我的机场

  - name: ChatGPT
    type: url-test
    use:
      - ✈️ 我的机场
    url: https://chatgpt.com/cdn-cgi/trace
    interval: 300
    tolerance: 50
    timeout: 5000
    max-failed-times: 3
    lazy: false
    expected-status: 200
    exclude-filter: '(?i)(🇭🇰|香港|港|\bHK\b|Hong\s*Kong|HKG)'

  - name: ♻️ 自动选择
    type: url-test
    use:
      - ✈️ 我的机场
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    timeout: 5000
    lazy: true

  - name: ⚖️ 负载均衡
    type: load-balance
    strategy: consistent-hashing
    use:
      - ✈️ 我的机场
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    timeout: 5000
    lazy: true

  - name: openAI
    type: select
    proxies:
      - ChatGPT
      - 🔰 节点选择
      - ♻️ 自动选择

  - name: 🌍 国外媒体
    type: select
    proxies:
      - 🔰 节点选择
      - ♻️ 自动选择
      - ⚖️ 负载均衡
      - 🎯 本地直连
    use:
      - ✈️ 我的机场

  - name: 🌏 国内媒体
    type: select
    proxies:
      - 🎯 本地直连
      - 🔰 节点选择

  - name: Ⓜ️ 微软服务
    type: select
    proxies:
      - 🎯 本地直连
      - 🔰 节点选择
      - ♻️ 自动选择

  - name: 📲 电报信息
    type: select
    proxies:
      - 🔰 节点选择
      - ♻️ 自动选择
      - 🎯 本地直连
    use:
      - ✈️ 我的机场

  - name: 🍎 苹果服务
    type: select
    proxies:
      - 🎯 本地直连
      - 🔰 节点选择
      - ♻️ 自动选择

  - name: SteamGame
    type: select
    proxies:
      - 🎯 本地直连
      - 🔰 节点选择
      - ♻️ 自动选择

  - name: 🎯 本地直连
    type: select
    proxies:
      - DIRECT

  - name: 🐟 漏网之鱼
    type: select
    proxies:
      - 🔰 节点选择
      - ♻️ 自动选择
      - ⚖️ 负载均衡
      - 🎯 本地直连

